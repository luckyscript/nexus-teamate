{
  "name": "nexus-teammate",
  "version": "1.0.0",
  "description": "AI-powered team collaboration platform",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_ENV=local midway-bin dev --ts",
    "build": "midway-bin build",
    "start": "cross-env NODE_ENV=production midway-bin start",
    "start:api": "cross-env NODE_ENV=production MIDWAY_PROCESS=api midway-bin start",
    "start:worker": "cross-env NODE_ENV=production MIDWAY_PROCESS=worker midway-bin start",
    "test": "cross-env NODE_ENV=unittest midway-bin test --ts",
    "lint": "eslint src/**/*.ts --fix"
  },
  "dependencies": {
    "@midwayjs/bootstrap": "^3.20.0",
    "@midwayjs/core": "^3.20.0",
    "@midwayjs/web": "^3.20.0",
    "@midwayjs/typeorm": "^3.20.0",
    "@midwayjs/validate": "^3.20.0",
    "@midwayjs/logger": "^3.20.0",
    "@midwayjs/cross-domain": "^3.20.0",
    "typeorm": "^0.3.20",
    "mysql2": "^3.11.0",
    "ioredis": "^5.4.1",
    "bullmq": "^5.25.0",
    "jsonwebtoken": "^9.0.2",
    "class-validator": "^0.14.1",
    "class-transformer": "^0.5.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@midwayjs/mock": "^3.20.0",
    "@types/node": "^22.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/uuid": "^10.0.0",
    "typescript": "~5.6.0",
    "@midwayjs/cli": "^2.0.0",
    "cross-env": "^7.0.3",
    "mwts": "^1.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}